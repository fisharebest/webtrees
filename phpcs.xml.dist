<?xml version="1.0"?>
<ruleset name="SYLO">
    <description>Sylo PHP coding standard.</description>

    <arg name="colors"/>
    <arg name="extensions" value="php"/>

    <file>index.php</file>
    <file>app</file>
    <file>tests</file>

    <exclude-pattern>bootstrap/cache/*</exclude-pattern>

    <rule ref="PSR12">
        <exclude name="Generic.Files.LineLength"/>
    </rule>
</ruleset>
