<?xml version="1.0" encoding="UTF-8"?>
<Report>
  <Title>
    <var var="I18N::translate('Occupations')"/>
  </Title>
  <Description>
    <var var="I18N::translate('A report of individuals who had a given occupation.')"/>
  </Description>
  <Input name="occupation" lookup="OCCU" type="text">
    <var var="I18N::translate('Occupation')"/>
  </Input>
  <Input name="sortby" type="select" default="NAME" options="NAME=&gt;I18N::translate('sort by name')|BIRT:DATE=&gt;I18N::translate('sort by date of birth')">
    <var var="I18N::translate('Sort order')"/>
  </Input>
  <Input name="pageSize" type="select" options="A4=&gt;I18N::translateContext('paper size','A4')|A3=&gt;I18N::translateContext('paper size', 'A3')|US-Letter=&gt;I18N::translateContext('paper size','Letter')|US-Tabloid=&gt;I18N::translateContext('paper size','Tabloid')">
    <var var="I18N::translate('Page size')"/>
  </Input>

  <Style name="footer" size="8" style="i"/>
  <Style name="header" size="16" style="b"/>
  <Style name="label" size="10" style="b"/>
  <Style name="text" size="9"/>

  <Doc pageSize="$pageSize" orientation="landscape" topmargin="62">
    <!-- Percentage-based columns for page-size-independent table layout -->
    <SetVar name="column_1_width" value="$PAGE_WIDTH * 0.20"/>
    <SetVar name="column_2_width" value="$PAGE_WIDTH * 0.15"/>
    <SetVar name="column_3_width" value="$PAGE_WIDTH * 0.18"/>
    <SetVar name="column_4_width" value="$PAGE_WIDTH * 0.15"/>
    <SetVar name="column_5_width" value="$PAGE_WIDTH * 0.15"/>
    <SetVar name="column_6_width" value="$PAGE_WIDTH * 0.17"/>
    <SetVar name="printedoccupation" value="0"/>
    <SetVar name="column_1_2_width" value="$column_1_width +$column_2_width"/>

    <Header>
      <Cell style="header" height="30" align="center" newline="1">
        <var var="I18N::translate('Occupations')"/>
      </Cell>
      <TextBox border="1" width="$column_1_width">
        <Text style="label">
          <var var="I18N::translate('Name')"/>
        </Text>
      </TextBox>
      <TextBox border="1" width="$column_2_width">
        <Text style="label">
          <var var="I18N::translate('Date of birth')"/>
        </Text>
      </TextBox>
      <!-- should print and sort by birth date -->
      <TextBox border="1" width="$column_3_width">
        <Text style="label">
          <var var="I18N::translate('Occupation')"/>
        </Text>
      </TextBox>
      <TextBox border="1" width="$column_4_width">
        <Text style="label">
          <var var="I18N::translate('Date')"/>
        </Text>
      </TextBox>
      <TextBox border="1" width="$column_5_width">
        <Text style="label">
          <var var="I18N::translate('Place')"/>
        </Text>
      </TextBox>
      <TextBox border="1" width="$column_6_width" newline="1">
        <Text style="label">
          <var var="I18N::translate('Note')"/>
        </Text>
      </TextBox>
    </Header>
    <Body>
      <List list="individual" filter1="OCCU CONTAINS $occupation" sortby="$sortby">
        <SetVar name="moreoccupation" value="0"/>
        <!-- Printed List counter -->
        <SetVar name="printedoccupation" value="$printedoccupation + 1"/>
        <Cell style="text" width="$column_1_width">
          <GetPersonName id=""/>
        </Cell>
        <Cell style="text" width="$column_2_width">
          <GedcomValue tag="BIRT:DATE" newline="1"/>
        </Cell>
        <RepeatTag tag="OCCU">
          <!-- Intend the fact line if more then one occupation -->
          <if condition="$moreoccupation==1">
            <Cell style="text" width="$column_1_2_width"> </Cell>
          </if>
          <Cell style="text" width="$column_3_width">
            <GedcomValue tag="OCCU"/>
          </Cell>
          <!-- Date of the fact -->
          <Cell style="text" width="$column_4_width">
            <GedcomValue tag="OCCU:DATE"/>
          </Cell>
          <!-- Place of the fact -->
          <Cell style="text" width="$column_5_width">
            <GedcomValue tag="OCCU:PLAC"/>
          </Cell>
          <!-- Note text -->
          <Cell style="text" width="$column_6_width" newline="1">
            <RepeatTag tag="OCCU">
              <GedcomValue tag="OCCU:NOTE"/>
            </RepeatTag>
          </Cell>
          <SetVar name="moreoccupation" value="1"/>
        </RepeatTag>
      </List>
      <Cell align="rightrtl" height="24" newline="1" style="label"><br/><var var="I18N::translate('Total individuals')"/>: <ListTotal/></Cell>
    </Body>
    <Footer>
      <WebtreesLogo/>
      <Cell align="rightrtl" newline="1" style="footer">
        <var var="I18N::translate('Page')"/> <PageNum/> <var var="I18N::translate('of')"/> <TotalPages/>
      </Cell>
    </Footer>
  </Doc>
</Report>
