<?xml version="1.0" encoding="UTF-8"?>
<Report>
  <Title>
    <var var="I18N::translate('Source')"/>
  </Title>
  <Description>
    <var var="I18N::translate('A report of facts which are supported by a given source.')"/>
  </Description>
  <Input name="sid" lookup="SOUR" default="" type="text">
    <var var="I18N::translate('Find a source')"/>
  </Input>
  <Input name="stype" type="select" default="facts" options="facts=&gt;I18N::translate('facts')|records=&gt;I18N::translate('records')">
    <var var="I18N::translate('Source type')"/>
  </Input>
  <Input name="sortby" type="select" default="BIRT:DATE" options="NAME=&gt;I18N::translate('sort by name')|BIRT:DATE=&gt;I18N::translate('sort by date of birth')">
    <var var="I18N::translate('Sort order')"/>
  </Input>
  <Input name="pageSize" type="select" options="A4=&gt;I18N::translateContext('paper size','A4')|A3=&gt;I18N::translateContext('paper size', 'A3')|US-Letter=&gt;I18N::translateContext('paper size','Letter')|US-Tabloid=&gt;I18N::translateContext('paper size','Tabloid')">
    <var var="I18N::translate('Page size')"/>
  </Input>

  <Style name="footer" size="8" style="i"/>
  <Style name="header" size="16" style="b"/>
  <Style name="label" size="10" style="b"/>
  <Style name="subheader" size="12" style="b"/>
  <Style name="text" size="9"/>

  <Doc pageSize="$pageSize" orientation="landscape" topmargin="62">
    <SetVar name="column_1_width" value="$PAGE_WIDTH * 0.30"/>
    <SetVar name="column_2_width" value="$PAGE_WIDTH * 0.15"/>
    <SetVar name="column_3_width" value="$PAGE_WIDTH * 0.45"/>
    <SetVar name="column_4_width" value="$PAGE_WIDTH * 0.15"/>
    <SetVar name="column_5_width" value="$PAGE_WIDTH * 0.15"/>
    <SetVar name="vspace" value="5"/>
    <SetVar name="printedsource" value="0"/>
    <SetVar name="moresourcespaceindi" value="$column_1_width +$column_2_width"/>
    <SetVar name="ignore" value="CHAN,CHIL,FAMC,FAMS,HUSB,OBJE,RESN,SEX,SOUR,TITL,WIFE,_UID,_WT_OBJE_SORT"/>

    <Header>
      <Cell style="header" height="30" align="center" newline="1"><var var="I18N::translate('Source')"/> -
        <Gedcom id="$sid"><GedcomValue tag="TITL"/></Gedcom>
      </Cell>
    </Header>
    <Body>
      <if condition="$stype=='facts'">
        <!-- List type -->
        <Cell align="center" newline="1" style="subheader">
          <var var="I18N::translate('Individuals')"/>
        </Cell>
        <TextBox height="$vspace" newline="1" padding="0"/>
        <!-- Individual Name -->
        <Cell border="1" style="label" width="$column_1_width">
          <var var="I18N::translate('Name')"/>
        </Cell>
        <!-- Birth date -->
        <Cell border="1" style="label" width="$column_2_width">
          <var var="I18N::translate('Date of birth')"/>
        </Cell>
        <!-- Name of the fact that contains the source -->
        <Cell border="1" style="label" width="$column_4_width">
          <var var="I18N::translate('Event')"/>
        </Cell>
        <!-- Date of the fact -->
        <Cell border="1" style="label" width="$column_5_width">
          <var var="I18N::translate('Date')"/>
        </Cell>
        <!-- Detailed source text -->
        <Cell border="1" newline="1" style="label">
          <var var="I18N::translate('Citation details')"/>
        </Cell>
        <TextBox height="$vspace" newline="1" padding="0"/>
        <!-- Individual List -->
        <List list="individual" filter1=":SOUR CONTAINS @$sid@" sortby="$sortby">
          <SetVar name="moresource" value="0"/>
          <SetVar name="printsource" value="0"/>
          <!-- Printed List counter -->
          <SetVar name="printedsource" value="$printedsource + 1"/>
          <!-- Individual Name -->
          <Cell style="text" width="$column_1_width">
            <GetPersonName id=""/>
          </Cell>
          <!-- Birth date -->
          <Cell style="text" width="$column_2_width">
            <GedcomValue tag="BIRT:DATE"/>
          </Cell>
          <Facts ignore="$ignore">
            <SetVar name="printfact" value="0"/>
            <RepeatTag tag="@fact:SOUR">
              <Gedcom id="@SOUR">
                <if condition="@ID==$sid">
                  <SetVar name="printfact" value="1"/>
                </if>
              </Gedcom>
            </RepeatTag>
            <if condition="$printfact==1">
              <SetVar name="printsource" value="0"/>
              <!-- Indent the fact line if more then one fact has source -->
              <if condition="$moresource==1">
                <Cell style="text" width="$moresourcespaceindi"> </Cell>
              </if>
              <!-- Name of the fact that contains the source -->
              <Cell style="text" width="$column_4_width">
                <var var="@fact"/>
              </Cell>
              <!-- Date of the fact -->
              <Cell style="text" width="$column_5_width">
                <GedcomValue tag="@fact:DATE"/>
              </Cell>
              <!-- Detailed source text -->
              <Cell style="text" newline="1">
                <SetVar name="repeatedSource" value="0"/>
                <RepeatTag tag="@fact:SOUR">
                  <Gedcom id="@SOUR">
                    <if condition="@ID==$sid">
                      <SetVar name="printsource" value="1"/>
                    </if>
                  </Gedcom>
                  <if condition="$printsource==1">
                    <if condition="$repeatedSource==1">; </if>
                    <if condition="@SOUR:PAGE!='' or @SOUR:DATA:TEXT!=''">
                      <SetVar name="repeatedSource" value="1"/>
                    </if>
                    <GedcomValue tag="SOUR:PAGE"/>
                    <if condition="@SOUR:DATA:TEXT!=''">
                      <if condition="@SOUR:PAGE!=''">
                        <br/>
                      </if>
                      <GedcomValue tag="SOUR:DATA:TEXT"/>
                    </if>
                    <SetVar name="printsource" value="0"/>
                  </if>
                </RepeatTag>
              </Cell>
              <SetVar name="moresource" value="1"/>
            </if>
            <SetVar name="printfact" value="0"/>
          </Facts>
        </List>
        <!-- Print the list counter -->
        <if condition="$printedsource==0">
          <Cell align="rightrtl" height="24" newline="1" style="label"><var var="I18N::translate('Total individuals')"/>: 0</Cell>
        </if>
        <if condition="$printedsource &gt; 0">
          <TextBox height="$vspace" newline="1" padding="0"/>
          <Cell align="rightrtl" height="24" newline="1" style="label"><var var="I18N::translate('Total individuals')"/>: <var var="printedsource"/></Cell>
        </if>
        <NewPage/>
        <!-- Family List -->
        <TextBox height="$vspace" newline="1" padding="0"/>
        <Cell align="center" newline="1" style="subheader">
          <var var="I18N::translate('Families')"/>
        </Cell>
        <TextBox height="$vspace" newline="1" padding="0"/>
        <!-- Family Name -->
        <Cell border="1" style="label" width="$column_3_width">
          <var var="I18N::translate('Name')"/>
        </Cell>
        <!-- Name of the fact that contains the source -->
        <Cell border="1" style="label" width="$column_4_width">
          <var var="I18N::translate('Event')"/>
        </Cell>
        <!-- Date of the fact -->
        <Cell border="1" style="label" width="$column_5_width">
          <var var="I18N::translate('Date')"/>
        </Cell>
        <!-- Detailed source text -->
        <Cell border="1" newline="1" style="label">
          <var var="I18N::translate('Citation details')"/>
        </Cell>
        <!-- Family List -->
        <TextBox height="$vspace" newline="1" padding="0"/>
        <SetVar name="printedsource" value="0"/>
        <List list="family" filter1=":SOUR CONTAINS @$sid@" sortby="MARR:DATE">
          <SetVar name="moresource" value="0"/>
          <SetVar name="printsource" value="0"/>
          <!-- Printed List counter -->
          <SetVar name="printedsource" value="$printedsource + 1"/>
          <!-- Family Name -->
          <Cell style="text" width="$column_3_width">
            <GetPersonName id=""/>
          </Cell>
          <Facts ignore="$ignore">
            <SetVar name="printfact" value="0"/>
            <RepeatTag tag="@fact:SOUR">
              <Gedcom id="@SOUR">
                <if condition="@ID==$sid">
                  <SetVar name="printfact" value="1"/>
                </if>
              </Gedcom>
            </RepeatTag>
            <if condition="$printfact==1">
              <SetVar name="printsource" value="0"/>
              <!-- Indent the fact line if more then one fact has source -->
              <if condition="$moresource==1">
                <Cell style="text" width="$column_3_width"> </Cell>
              </if>
              <!-- Name of the fact that contains the source -->
              <Cell style="text" width="$column_4_width">
                <if condition="@fact=='MARR'">
                  <!-- Print different type of marriages -->
                  <if condition="@MARR:TYPE==''">
                    <var var="@fact"/>
                  </if>
                  <if condition="@MARR:TYPE=='Religious'">
                    <var var="I18N::translate('Religious marriage')"/>
                  </if>
                  <if condition="@MARR:TYPE=='Civil'">
                    <var var="I18N::translate('Civil marriage')"/>
                  </if>
                  <if condition="@MARR:TYPE=='Partners'">
                    <var var="I18N::translate('Registered partnership')"/>
                  </if>
                </if>
                <if condition="@fact!='MARR'">
                  <var var="@fact"/>
                </if>
              </Cell>
              <!-- Date of the fact -->
              <Cell style="text" width="$column_5_width">
                <GedcomValue tag="@fact:DATE"/>
              </Cell>
              <!-- Detailed source text -->
              <Cell style="text" newline="1">
                <SetVar name="repeatedSource" value="0"/>
                <RepeatTag tag="@fact:SOUR">
                  <Gedcom id="@SOUR">
                    <if condition="@ID==$sid">
                      <SetVar name="printsource" value="1"/>
                    </if>
                  </Gedcom>
                  <if condition="$printsource==1">
                    <if condition="$repeatedSource==1">; </if>
                    <if condition="@SOUR:PAGE!='' or @SOUR:DATA:TEXT!=''">
                      <SetVar name="repeatedSource" value="1"/>
                    </if>
                    <GedcomValue tag="SOUR:PAGE"/>
                    <if condition="@SOUR:DATA:TEXT!=''">
                      <if condition="@SOUR:PAGE!=''">
                        <br/>
                      </if>
                      <GedcomValue tag="SOUR:DATA:TEXT"/>
                    </if>
                    <SetVar name="printsource" value="0"/>
                  </if>
                </RepeatTag>
              </Cell>
              <SetVar name="moresource" value="1"/>
            </if>
            <SetVar name="printfact" value="0"/>
          </Facts>
        </List>
        <!-- Print the list counter -->
        <if condition="$printedsource==0">
          <Cell align="rightrtl" height="24" newline="1" style="label"><var var="I18N::translate('Total families')"/>: 0</Cell>
        </if>
        <if condition="$printedsource &gt; 0">
          <TextBox height="$vspace" newline="1" padding="0"/>
          <Cell align="rightrtl" height="24" newline="1" style="label"><var var="I18N::translate('Total families')"/>: <var var="printedsource"/></Cell>
        </if>
        <TextBox height="$vspace" newline="1" padding="0"/>
      </if>
      <if condition="$stype=='records'">
        <!-- List type -->
        <Cell align="center" newline="1" style="subheader">
          <var var="I18N::translate('Individuals')"/>
        </Cell>
        <TextBox height="$vspace" newline="1" padding="0"/>
        <!-- Individual Name -->
        <Cell border="1" style="label" width="$column_1_width">
          <var var="I18N::translate('Name')"/>
        </Cell>
        <!-- Birth date -->
        <Cell border="1" style="label" width="$column_4_width">
          <var var="I18N::translate('Date of birth')"/>
        </Cell>
        <Cell border="1" style="label" width="$column_5_width">
          <var var="I18N::translate('Place of birth')"/>
        </Cell>
        <Cell border="1" style="label" width="$column_4_width">
          <var var="I18N::translate('Date of death')"/>
        </Cell>
        <Cell border="1" style="label" width="$column_5_width">
          <var var="I18N::translate('Place of death')"/>
        </Cell>
        <!-- Detailed source text -->
        <Cell border="1" newline="1" style="label">
          <var var="I18N::translate('Citation details')"/>
        </Cell>
        <TextBox height="$vspace" newline="1" padding="0"/>
        <!-- Individual List -->
        <List list="individual" filter1="SOUR CONTAINS @$sid@" sortby="$sortby">
          <!-- Printed List counter -->
          <SetVar name="printedsource" value="$printedsource + 1"/>
          <!-- Individual Name -->
          <Cell style="text" width="$column_1_width">
            <GetPersonName id=""/>
          </Cell>
          <!-- Birth date -->
          <Cell style="text" width="$column_5_width">
            <GedcomValue tag="BIRT:DATE"/>
          </Cell>
          <!-- Birth place -->
          <Cell style="text" width="$column_4_width">
            <GedcomValue tag="BIRT:PLAC"/>
          </Cell>
          <!-- Death date -->
          <Cell style="text" width="$column_5_width">
            <GedcomValue tag="DEAT:DATE"/>
          </Cell>
          <!-- Death place -->
          <Cell style="text" width="$column_4_width">
            <GedcomValue tag="DEAT:PLAC"/>
          </Cell>
          <!-- Detailed source text -->
          <Cell style="text" newline="1">
            <GedcomValue tag="SOUR:PAGE"/>
            <if condition="@SOUR:DATA:TEXT!=''">
              <br/>
              <GedcomValue tag="SOUR:DATA:TEXT"/>
            </if>
          </Cell>
        </List>
        <!-- Print the list counter -->
        <if condition="$printedsource==0">
          <Cell align="rightrtl" height="24" newline="1" style="label"><var var="I18N::translate('Total individuals')"/>: 0</Cell>
        </if>
        <if condition="$printedsource &gt; 0">
          <TextBox height="$vspace" newline="1" padding="0"/>
          <Cell align="rightrtl" height="24" newline="1" style="label"><var var="I18N::translate('Total individuals')"/>: <var var="printedsource"/></Cell>
        </if>
        <NewPage/>
        <!-- Family List -->
        <TextBox height="$vspace" newline="1" padding="0"/>
        <Cell align="center" newline="1" style="subheader">
          <var var="I18N::translate('Families')"/>
        </Cell>
        <TextBox height="$vspace" newline="1" padding="0"/>
        <!-- Family Name -->
        <Cell border="1" style="label" width="$column_3_width">
          <var var="I18N::translate('Name')"/>
        </Cell>
        <!-- Name of the fact that contains the source -->
        <Cell border="1" style="label" width="$column_5_width">
          <var var="I18N::translate('Date of marriage')"/>
        </Cell>
        <!-- Date of the fact -->
        <Cell border="1" style="label" width="$column_4_width">
          <var var="I18N::translate('Place of marriage')"/>
        </Cell>
        <!-- Detailed source text -->
        <Cell border="1" newline="1" style="label">
          <var var="I18N::translate('Citation details')"/>
        </Cell>
        <!-- Family List -->
        <TextBox height="$vspace" newline="1" padding="0"/>
        <SetVar name="printedsource" value="0"/>
        <List list="family" filter1="SOUR CONTAINS @$sid@" sortby="MARR:DATE">
          <SetVar name="printsource" value="0"/>
          <!-- Printed List counter -->
          <SetVar name="printedsource" value="$printedsource + 1"/>
          <!-- Family Name -->
          <Cell style="text" width="$column_3_width">
            <GetPersonName id=""/>
          </Cell>
          <!-- Date of the fact -->
          <Cell style="text" width="$column_5_width">
            <GedcomValue tag="MARR:DATE"/>
          </Cell>
          <!-- Place of the fact -->
          <Cell style="text" width="$column_4_width">
            <GedcomValue tag="MARR:PLAC"/>
          </Cell>
          <!-- Detailed source text -->
          <Cell style="text" newline="1">
            <GedcomValue tag="SOUR:PAGE"/>
            <if condition="@SOUR:DATA:TEXT!=''">
              <br/>
              <GedcomValue tag="SOUR:DATA:TEXT"/>
            </if>
          </Cell>
        </List>
        <!-- Print the list counter -->
        <if condition="$printedsource==0">
          <Cell align="rightrtl" height="24" newline="1" style="label"><var var="I18N::translate('Total families')"/>: 0</Cell>
        </if>
        <if condition="$printedsource &gt; 0">
          <TextBox height="$vspace" newline="1" padding="0"/>
          <Cell align="rightrtl" height="24" newline="1" style="label"><var var="I18N::translate('Total families')"/>: <var var="printedsource"/></Cell>
        </if>
        <TextBox height="$vspace" newline="1" padding="0"/>
      </if>
    </Body>
    <Footer>
      <WebtreesLogo/>
      <Cell align="rightrtl" newline="1" style="footer">
        <var var="I18N::translate('Page')"/> <PageNum/> <var var="I18N::translate('of')"/> <TotalPages/>
      </Cell>
    </Footer>
  </Doc>
</Report>
