<?xml version="1.0" encoding="UTF-8"?>
<Report>
  <Title>
    <var var="I18N::translate('Burials')"/>
  </Title>
  <Description>
    <var var="I18N::translate('A report of individuals who were buried in a given place.')"/>
  </Description>
  <Input name="deathplace" lookup="PLAC" type="text">
    <var var="I18N::translate('Burial place contains')"/>
  </Input>
  <Input name="sortby" type="select" default="NAME" options="NAME=&gt;I18N::translate('sort by name')|DEAT:DATE=&gt;I18N::translate('sort by date of death')">
    <var var="I18N::translate('Sort order')"/>
  </Input>
  <Input name="adlist" type="select" default="none" options="none=&gt;I18N::translate('None')|_MARNM=&gt;I18N::translate('Married name')|HUSB=&gt;I18N::translate('Husband')">
    <var var="I18N::translate('Names')"/>
  </Input>
  <Input name="pageSize" type="select" options="A4=&gt;I18N::translateContext('paper size','A4')|A3=&gt;I18N::translateContext('paper size', 'A3')|US-Letter=&gt;I18N::translateContext('paper size','Letter')|US-Tabloid=&gt;I18N::translateContext('paper size','Tabloid')">
    <var var="I18N::translate('Page size')"/>
  </Input>

  <Style name="footer" size="8" style="i"/>
  <Style name="header" size="16" style="b"/>
  <Style name="label" size="10" style="b"/>
  <Style name="text" size="9"/>

  <Doc pageSize="$pageSize" orientation="landscape" topmargin="62">
    <SetVar name="column_1_width" value="$PAGE_WIDTH * 0.25"/>
    <SetVar name="column_2_width" value="$PAGE_WIDTH * 0.15"/>
    <SetVar name="column_3_width" value="$PAGE_WIDTH * 0.15"/>
    <SetVar name="column_4_width" value="$PAGE_WIDTH * 0.30"/>
    <SetVar name="column_5_width" value="$PAGE_WIDTH * 0.15"/>

    <Header>
      <Cell style="header" height="30" align="center" newline="1">
        <var var="I18N::translate('Burials')"/>
      </Cell>
      <Cell style="label" border="1" width="$column_1_width">
        <var var="I18N::translate('Name')"/>
      </Cell>
      <Cell style="label" border="1" width="$column_2_width">
        <var var="I18N::translate('Date of death')"/>
      </Cell>
      <Cell style="label" border="1" width="$column_3_width">
        <var var="I18N::translate('Date of burial')"/>
      </Cell>
      <Cell style="label" border="1" width="$column_4_width">
        <var var="I18N::translate('Place of burial')"/>
      </Cell>
      <Cell style="label" border="1" width="$column_5_width" newline="1">
        <var var="I18N::translate('Note')"/>
      </Cell>
    </Header>
    <Body>
      <List list="individual" filter1="BURI:PLAC CONTAINS $deathplace" filter2="LIKE /%\n1 BURI%/" sortby="$sortby">
        <Cell style="text" width="$column_1_width">
          <GetPersonName id=""/>
          <if condition="$adlist=='_MARNM'">
            <RepeatTag tag="NAME:_MARNM">
              <br/>
              <GedcomValue tag="_MARNM"/>
            </RepeatTag>
          </if>
          <if condition="($adlist=='HUSB') and (@SEX=='F')">
            <RepeatTag tag="FAMS">
              <Gedcom id="@FAMS:@HUSB">
                <br/>
                <GetPersonName id=""/>
              </Gedcom>
            </RepeatTag>
          </if>
        </Cell>
        <Cell style="text" width="$column_2_width">
          <GedcomValue tag="DEAT:DATE" newline="1"/>
        </Cell>
        <Cell style="text" width="$column_3_width">
          <GedcomValue tag="BURI:DATE" newline="1"/>
        </Cell>
        <Cell style="text" width="$column_4_width">
          <GedcomValue tag="BURI:CEME"/>
          <if condition="@BURI:CEME !== ''">, </if>
          <GedcomValue tag="BURI:PLAC"/>
        </Cell>
        <Cell style="text" width="$column_5_width" newline="1">
          <GedcomValue tag="BURI:NOTE"/>
        </Cell>
      </List>
      <Cell align="rightrtl" height="24" newline="1" style="label"><br/><var var="I18N::translate('Total individuals')"/>: <ListTotal/></Cell>
    </Body>
    <Footer>
      <WebtreesLogo/>
      <Cell align="rightrtl" newline="1" style="footer">
        <var var="I18N::translate('Page')"/> <PageNum/> <var var="I18N::translate('of')"/> <TotalPages/>
      </Cell>
    </Footer>
  </Doc>
</Report>
