<?xml version="1.0" encoding="UTF-8"?>
<Report>
  <Title>
    <var var="I18N::translate('Deaths')"/>
  </Title>
  <Description>
    <var var="I18N::translate('A report of individuals who died in a given time or place.')"/>
  </Description>
  <Input name="name" lookup="NAME" type="text">
    <var var="I18N::translate('Name')"/>
  </Input>
  <Input name="deathplace" lookup="PLAC" type="text">
    <var var="I18N::translate('Death place contains')"/>
  </Input>
  <Input name="deathdate1" lookup="DATE" type="text">
    <var var="I18N::translate('Death date range start')"/>
  </Input>
  <Input name="deathdate2" lookup="DATE" type="text">
    <var var="I18N::translate('Death date range end')"/>
  </Input>
  <Input name="sortby" type="select" default="NAME" options="NAME=&gt;I18N::translate('sort by name')|DEAT:DATE=&gt;I18N::translate('sort by date of death')">
    <var var="I18N::translate('Sort order')"/>
  </Input>
  <Input name="adlist" type="select" default="none" options="none=&gt;I18N::translate('None')|_MARNM=&gt;I18N::translate('Married name')|HUSB=&gt;I18N::translate('Husband')">
    <var var="I18N::translate('Names')"/>
  </Input>
  <Input name="pageSize" type="select" options="A4=&gt;I18N::translateContext('paper size','A4')|A3=&gt;I18N::translateContext('paper size', 'A3')|US-Letter=&gt;I18N::translateContext('paper size','Letter')|US-Tabloid=&gt;I18N::translateContext('paper size','Tabloid')">
    <var var="I18N::translate('Page size')"/>
  </Input>

  <Style name="footer" size="8" style="i"/>
  <Style name="header" size="16" style="b"/>
  <Style name="label" size="10" style="b"/>
  <Style name="text" size="9"/>

  <Doc pageSize="$pageSize" orientation="landscape" topmargin="62">
    <SetVar name="column_1_width" value="$PAGE_WIDTH * 0.30"/>
    <SetVar name="column_2_width" value="$PAGE_WIDTH * 0.15"/>
    <SetVar name="column_3_width" value="$PAGE_WIDTH * 0.20"/>
    <SetVar name="column_4_width" value="$PAGE_WIDTH * 0.35"/>

    <Header>
      <Cell style="header" height="30" align="center" newline="1">
        <var var="I18N::translate('Deaths')"/>
      </Cell>
      <Cell border="1" width="$column_1_width" style="label">
        <var var="I18N::translate('Name')"/>
      </Cell>
      <Cell border="1" width="$column_2_width" style="label">
        <var var="I18N::translate('Date')"/>
      </Cell>
      <Cell border="1" width="$column_3_width" style="label">
        <var var="I18N::translate('Place')"/>
      </Cell>
      <Cell border="1" width="$column_4_width" newline="1" style="label">
        <var var="I18N::translate('Source')"/>
      </Cell>
    </Header>
    <Body>
      <List list="individual" filter1="DEAT:PLAC CONTAINS $deathplace" filter2="DEAT:DATE GTE $deathdate1" filter3="DEAT:DATE LTE $deathdate2" filter4="NAME CONTAINS $name" filter5="LIKE /%\n1 DEAT%/" sortby="$sortby">
        <TextBox width="$column_1_width">
          <Text style="text">
            <GetPersonName/>
            <if condition="$adlist=='_MARNM'">
              <RepeatTag tag="NAME">
                <if condition="@NAME:TYPE=='married'">
                  <br/>
                  <GedcomValue tag="NAME"/>
                </if>
              </RepeatTag>
              <RepeatTag tag="NAME:_MARNM">
                <br/>
                <GedcomValue tag="_MARNM"/>
              </RepeatTag>
            </if>
            <if condition="($adlist=='HUSB') and (@SEX=='F')">
              <RepeatTag tag="FAMS">
                <Gedcom id="@FAMS:@HUSB">
                  <br/>
                  <GetPersonName/>
                </Gedcom>
              </RepeatTag>
            </if>
          </Text>
        </TextBox>
        <TextBox width="$column_2_width">
          <Text style="text">
            <GedcomValue tag="DEAT:DATE" newline="1"/>
          </Text>
        </TextBox>
        <TextBox width="$column_3_width">
          <Text style="text">
            <GedcomValue tag="DEAT:PLAC"/>
          </Text>
        </TextBox>
        <TextBox width="$column_4_width" newline="1">
          <!-- Only with multiple sources use line feed (br) -->
          <SetVar name="usebr" value="0"/>
          <Text style="text">
            <RepeatTag tag="DEAT:SOUR">
              <if condition="$usebr==1">
                <br/>
              </if>
              <Gedcom id="@SOUR"><if condition="@AUTH!=''"><GedcomValue tag="AUTH"/>, </if>
                «<GedcomValue tag="TITL"/>»
                <if condition="@PUBL!=''"> (<GedcomValue tag="PUBL"/>)</if>
              </Gedcom>
              <if condition="@PAGE!=''">: <GedcomValue tag="SOUR:PAGE"/></if>
              <GedcomValue tag="SOUR:DATA:TEXT"/>
              <SetVar name="usebr" value="1"/>
            </RepeatTag>
          </Text>
        </TextBox>
      </List>
      <Cell align="rightrtl" height="24" newline="1" style="label"><br/><var var="I18N::translate('Total individuals')"/>: <ListTotal/></Cell>
    </Body>
    <Footer>
      <WebtreesLogo/>
      <Cell align="rightrtl" newline="1" style="footer">
        <var var="I18N::translate('Page')"/> <PageNum/> <var var="I18N::translate('of')"/> <TotalPages/>
      </Cell>
    </Footer>
  </Doc>
</Report>
