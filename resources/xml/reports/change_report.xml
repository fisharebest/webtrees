<?xml version="1.0" encoding="UTF-8"?>
<Report>
  <Title>
    <var var="I18N::translate('Changes')"/>
  </Title>
  <Description>
    <var var="I18N::translate('A report of recent and pending changes.')"/>
  </Description>
  <Input name="changeRangeStart" lookup="DATE" type="text" default="NOW-30">
    <var var="I18N::translate('Starting range of change dates')"/>
  </Input>
  <Input name="changeRangeEnd" lookup="DATE" type="text" default="NOW">
    <var var="I18N::translate('Ending range of change dates')"/>
  </Input>
  <Input name="sortby" type="select" default="CHAN" options="CHAN=&gt;I18N::translate('sort by date')|NAME=&gt;I18N::translate('sort by name')|BIRT:DATE=&gt;I18N::translate('sort by date of birth')">
    <var var="I18N::translate('Sort order')"/>
  </Input>
  <Input name="pending" type="select" options="yes=&gt;I18N::translate('yes')|no=&gt;I18N::translate('no')">
    <var var="I18N::translate('Show pending changes')"/>
  </Input>
  <Input name="pageSize" type="select" options="A4=&gt;I18N::translateContext('paper size','A4')|A3=&gt;I18N::translateContext('paper size', 'A3')|US-Letter=&gt;I18N::translateContext('paper size','Letter')|US-Tabloid=&gt;I18N::translateContext('paper size','Tabloid')">
    <var var="I18N::translate('Page size')"/>
  </Input>
  <Input name="pageorient" type="select" default="landscape" options="landscape=&gt;I18N::translate('Landscape')|portrait=&gt;I18N::translate('Portrait')">
    <var var="I18N::translate('Orientation')"/>
  </Input>

  <Style name="footer" size="8" style="i"/>
  <Style name="header" size="16" style="b"/>
  <Style name="subheader" size="12" style="b"/>
  <Style name="label" size="10" style="b"/>
  <Style name="text" size="9"/>

  <Doc pageSize="$pageSize" orientation="$pageorient">
    <SetVar name="column_1_width" value="$PAGE_WIDTH * 0.40"/>
    <SetVar name="column_2_width" value="$PAGE_WIDTH * 0.35"/>
    <SetVar name="column_3_width" value="$PAGE_WIDTH * 0.25"/>

    <Header>
      <Cell style="header" height="30" align="center" newline="1">
        <var var="I18N::translate('Changes')"/>
      </Cell>
    </Header>
    <Body>
      <!-- Pending changes section Header -->
      <if condition="$pending=='yes'">
        <Cell align="center" height="20" newline="1" style="subheader">
          <var var="I18N::translate('Pending changes')"/>
        </Cell>
        <Cell border="1" width="$column_1_width" style="label">
          <var var="I18N::translate('Name')"/>
        </Cell>
        <Cell border="1" width="$column_2_width" style="label">
          <var var="I18N::translate('Differences')"/>
        </Cell>
        <Cell border="1" width="$column_3_width" newline="1" style="label">
          <var var="I18N::translate('Last change')"/>
        </Cell>
        <!-- Pending Changes Section Data -->
        <List list="pending" sortby="$sortby">
          <TextBox height="12" width="$column_1_width">
            <Text style="text">
              <GetPersonName id=""/>
            </Text>
          </TextBox>
          <TextBox height="12" width="$column_2_width">
            <Facts ignore="CHAN" families="0" diff="true">
              <Text style="text">
                <var var="@fact"/>
                <GedcomValue tag="@fact:DATE"/>
                <br/>
              </Text>
            </Facts>
          </TextBox>
          <TextBox height="12" width="$column_3_width" newline="1">
            <Text style="text"><GedcomValue tag="CHAN:DATE"/><GedcomValue tag="CHAN:DATE:TIME"/> - <GedcomValue tag="CHAN:_WT_USER"/></Text>
          </TextBox>
        </List>
        <Cell align="rightrtl" height="24" newline="1" style="label">
          <var var="I18N::translate('Total pending changes: ')"/>
          <ListTotal/>
          <br/>
        </Cell>
      </if>
      <!-- Recent Changes Section Header -->
      <Cell align="center" height="20" newline="1" style="subheader"><var var="I18N::translate('Recent changes')"/><var var="changeRangeStart" format="date"/> - <var var="changeRangeEnd" format="date"/></Cell>
      <Cell border="1" width="$column_1_width" style="label">
        <var var="I18N::translate('Name')"/>
      </Cell>
      <Cell border="1" width="$column_2_width" style="label">
        <var var="I18N::translate('Birth')"/> - <var var="I18N::translate('Death')"/>
      </Cell>
      <Cell border="1" width="$column_3_width" newline="1" style="label">
        <var var="I18N::translate('Last change')"/>
      </Cell>
      <!-- Recent Changes Section Data -->
      <List list="individual" filter1="CHAN:DATE LTE $changeRangeEnd" filter2="CHAN:DATE GTE $changeRangeStart" sortby="$sortby">
        <TextBox height="12" width="$column_1_width">
          <Text style="text">
            <GetPersonName id=""/>
          </Text>
        </TextBox>
        <TextBox height="12" width="$column_2_width">
          <Text style="text"><var var="I18N::translate('Birth')"/>: <GedcomValue tag="BIRT:DATE"/><br/><var var="I18N::translate('Death')"/>: <GedcomValue tag="DEAT:DATE"/></Text>
        </TextBox>
        <TextBox height="12" width="$column_3_width" newline="1">
          <Text style="text"><GedcomValue tag="CHAN:DATE"/><GedcomValue tag="CHAN:DATE:TIME"/> - <GedcomValue tag="CHAN:_WT_USER"/></Text>
        </TextBox>
      </List>
      <Cell align="rightrtl" height="24" newline="1" style="label">
        <var var="I18N::translate('Total accepted changes: ')"/>
        <ListTotal/>
      </Cell>
    </Body>
    <Footer>
      <WebtreesLogo/>
      <Cell align="rightrtl" newline="1" style="footer">
        <var var="I18N::translate('Page')"/> <PageNum/> <var var="I18N::translate('of')"/> <TotalPages/>
      </Cell>
    </Footer>
  </Doc>
</Report>
