<?php

declare(strict_types=1);

use Fisharebest\Webtrees\Charts\GeoChartData;
use Fisharebest\Webtrees\I18N;

/**
 * @var string       $chart_color2
 * @var string       $chart_color3
 * @var GeoChartData $chart_data
 * @var string       $chart_title
 * @var string       $language
 * @var string       $region
 */

$id = 'wt-chart-' . bin2hex(random_bytes(8));

$chart_options = [
    'plugins'   => [
        'title' => [
            'display' => true,
            'text'    => $chart_title,
        ],
    ],
    'region'    => $region,
    'colorAxis' => [
        'colors' => [
            '#' . $chart_color3,
            '#' . $chart_color2,
        ],
    ],
];

?>

<?php if (!$chart_data->hasData()) : ?>
    <?= I18N::translate('This information is not available.') ?>
<?php else : ?>
    <div class="d-grid mb-3">
        <div class="card">
            <div class="card-header">
                <?= $chart_title ?>
            </div>
            <div class="card-body">
                <div class="wt-chart-container" style="height: 24rem;">
                    <canvas id="<?= $id ?>"
                            title="<?= $chart_title ?>"
                            data-wt-chart-type="geo"
                            data-wt-chart-data="<?= e(json_encode($chart_data, JSON_THROW_ON_ERROR)) ?>"
                            data-wt-chart-options="<?= e(json_encode($chart_options, JSON_THROW_ON_ERROR)) ?>"
                    ></canvas>
                </div>
            </div>
        </div>
    </div>
<?php endif; ?>
