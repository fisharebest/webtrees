<?php

declare(strict_types=1);

use Fisharebest\Webtrees\Charts\BarChartData;
use Fisharebest\Webtrees\I18N;

/**
 * @var BarChartData            $chart_data
 * @var array<string,mixed>     $chart_options
 * @var string                  $chart_title
 * @var string                  $language
 */

$id = 'wt-chart-' . bin2hex(random_bytes(8));

?>

<?php if (!$chart_data->hasData()) : ?>
    <?= I18N::translate('This information is not available.') ?>
<?php else : ?>
    <div class="wt-chart-container" style="height: 20rem;">
        <canvas id="<?= $id ?>"
                title="<?= $chart_title ?>"
                data-wt-chart-type="column"
                data-wt-chart-data="<?= e(json_encode($chart_data, JSON_THROW_ON_ERROR)) ?>"
                data-wt-chart-options="<?= e(json_encode($chart_options, JSON_THROW_ON_ERROR)) ?>"
        ></canvas>
    </div>
<?php endif; ?>
